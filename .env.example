# ── Database ────────────────────────────────────────────────────────────────
# asyncpg driver is required (FastAPI is async)
# Use localhost when running server locally, postgres when running in Docker
DATABASE_URL=postgresql+asyncpg://vaaniq:vaaniq@localhost:5432/vaaniq

# ── Test env (required to run tests locally) ─────────────────────────────────
# Create test DB once: docker exec vaaniq-postgres-1 psql -U vaaniq -c "CREATE DATABASE vaaniq_test;"
# Use Redis DB 1 (not 0) to avoid mixing test data with dev cache.
TEST_DATABASE_URL=postgresql+asyncpg://vaaniq:vaaniq@localhost:5432/vaaniq_test
TEST_REDIS_URL=redis://localhost:6379/1
TEST_SECRET_KEY=test-secret
TEST_FERNET_KEY=

# Optional: read replica for analytics queries (leave empty for local dev)
DATABASE_REPLICA_URL=

# ── Redis ────────────────────────────────────────────────────────────────────
# Used by Celery (background tasks) and /ready health check
# Use localhost when running server locally, redis when running in Docker
REDIS_URL=redis://localhost:6379/0

# ── Security (REQUIRED) ──────────────────────────────────────────────────────
# Signs JWT access + refresh tokens — keep secret, never commit
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production

# Encrypts BYOK API keys stored in the database — never rotate without migrating existing keys
# Generate: uv run python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins — never use * in production
ALLOWED_ORIGINS=http://localhost:3000

# ── App ──────────────────────────────────────────────────────────────────────
# development → enables /docs (Swagger UI)
# production  → disables /docs
ENVIRONMENT=development

# Public URL of this server — used for Twilio callback URLs
BACKEND_URL=http://localhost:8000

# ── LiveKit (voice pipeline) ──────────────────────────────────────────────────
# Cloud: sign up at livekit.io → copy from project settings
# Self-hosted: run livekit-server locally (see docker-compose.yml)
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=DnO_GaXa2xG4gEcUYullHAgrZ7AiyLqgb0xkFRXAZlI
# SIP domain (optional — auto-derived from LIVEKIT_URL for livekit.cloud)
# LIVEKIT_SIP_DOMAIN=my-project.sip.livekit.cloud

# ── Observability (optional for local dev) ───────────────────────────────────
# Set in staging/production only
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=

# ── File Storage (Sprint 3+) ──────────────────────────────────────────────────
# Added in Sprint 3 when knowledge base / document uploads are implemented
# Local dev: files saved to disk
# Production: AWS S3
# STORAGE_BACKEND=s3
# AWS_S3_BUCKET=
# AWS_REGION=
